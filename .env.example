# OBS Captions — provider API keys
# Copy to .env and fill in only the keys for the engine(s) you use.

# OpenAI Realtime STT (engine = "openai")
OPENAI_API_KEY=

# ElevenLabs Realtime STT (engine = "elevenlabs")
ELEVENLABS_API_KEY=

# Google Gemini Live (engine = "google", mode = "gemini")
GEMINI_API_KEY=

# Google Speech-to-Text v2 streaming (engine = "google", mode = "speech_v2")
GOOGLE_CLOUD_PROJECT=

# xAI Grok transcribe (engine = "xai")
XAI_API_KEY=

# OpenRouter Whisper batch (engine = "openrouter")
OPENROUTER_API_KEY=

# Replicate Whisper batch (engine = "replicate")
REPLICATE_API_TOKEN=

# AssemblyAI Universal Streaming (engine = "assemblyai")
ASSEMBLYAI_API_KEY=

# Deepgram Nova-3 live streaming (engine = "deepgram")
DEEPGRAM_API_KEY=

# Groq Whisper utterance-mode (engine = "groq")
GROQ_API_KEY=

# Azure Cognitive Services Speech SDK (engine = "azure")
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# OBS WebSocket password (obs-websocket v5, only needed for --sink obs/both)
OBS_WS_PASSWORD=
